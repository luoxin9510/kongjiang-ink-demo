}
{ 投票_志勇 == 1:
    ~ 票_突围 = 票_突围 + 1
}
{ 投票_志勇 == 2:
    ~ 票_天台 = 票_天台 + 1
}
{ 投票_志勇 == 3:
    ~ 票_仪式 = 票_仪式 + 1
}
{ 投票_砚波 == 1:
    ~ 票_突围 = 票_突围 + 1
}
