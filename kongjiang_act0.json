,null],"调查_看窗外":["#","^speaker:player","/#","ev",{"f()":"tick回合"},"pop","/ev","\n","ev",{"f()":"tick调查"},"pop","/ev","\n","^你贴近窗缝。铁皮的边缘已经生锈，能看到楼下空荡荡的篮球场被一圈黄色警戒线圈着。","\n","ev",80,{"f()":"掷技能"},"/ev",{"temp=":"ok"},"\n","#","^roll:侦察,80,","ev",{"VAR?":"上次骰值"},"out","/ev","^,","ev",{"VAR?":"上次结果"},"out","/ev","/#","^〔侦察 80 · 骰 ","ev",{"VAR?":"上次骰值"},"out","/ev","^ · ","ev",{"f()":"档位名"},"out","/ev","^〕","\n",["ev",{"VAR?":"上次结果"},0,"==","/ev",{"->":".^.b","c":true},{"b":["\n","^你看得太久。视野模糊了一下，再聚焦时，远处的列队不见了——但其中一个白点正抬头看向你的窗户。","\n","ev",{"VAR?":"隐约不安"},{"f()":"推进觉知"},"pop","/ev","\n",{"->":".^.^.^.48"},null]}],["ev",{"VAR?":"ok"},"/ev",{"->":".^.b","c":true},{"b":["\n","^远处有一队穿白色防护服的人影列队走过——他们的步频整齐得过分，整齐得不像人。","\n","ev",{"VAR?":"隐约不安"},{"f()":"推进觉知"},"pop","/ev","\n",{"->":".^.^.^.48"},null]}],[{"->":".^.b"},{"b":["\n","^什么也没看清楚，只是几个白点在远处晃了晃。","\n",{"->":".^.^.^.48"},null]}],"nop","\n",{"->":".^.^.顶层"},null],"调查_查门":["#","^speaker:player","/#","ev",{"f()":"tick回合"},"pop","/ev","\n","ev",{"f()":"tick调查"},"pop","/ev","\n","^你走到门口。门是冷的，比平时冷。门把手上有一层薄薄的水汽。","\n","ev",80,{"f()":"掷技能"},"/ev",{"temp=":"ok"},"\n","#","^roll:侦察,80,","ev",{"VAR?":"上次骰值"},"out","/ev","^,","ev",{"VAR?":"上次结果"},"out","/ev","/#","^〔侦察 80 · 骰 ","ev",{"VAR?":"上次骰值"},"out","/ev","^ · ","ev",{"f()":"档位名"},"out","/ev","^〕","\n",["ev",{"VAR?":"上次结果"},0,"==","/ev",{"->":".^.b","c":true},{"b":["\n","^你贴得太近，鼻尖几乎抵到门板。门后忽然传来一声极轻的「呼」——是吐气声。你猛地后退。","\n","ev",{"VAR?":"隐约不安"},{"f()":"推进觉知"},"pop","/ev","\n",{"->":".^.^.^.48"},null]}],["ev",{"VAR?":"ok"},"/ev",{"->":".^.b","c":true},{"b":["\n","^门缝下方渗进一道暗色的痕迹，颜色像稀释的酱油。指尖蘸了一下——黏稠，带着甜味。","\n","ev",{"VAR?":"隐约不安"},{"f()":"推进觉知"},"pop","/ev","\n",{"->":".^.^.^.48"},null]}],[{"->":".^.b"},{"b":["\n","^门把手是凉的。除此之外没什么不对。","\n",{"->":".^.^.^.48"},null]}],"nop","\n",{"->":".^.^.顶层"},null],"调查_衣柜":["#","^speaker:player","/#","ev",{"f()":"tick回合"},"pop","/ev","\n","ev",{"f()":"tick调查"},"pop","/ev","\n","^你蹲到自己床位旁的小柜子前。最深处有一个不合时宜的东西——你很久前买的，没告诉过任何人。","\n","ev",80,{"f()":"掷技能"},"/ev",{"temp=":"ok"},"\n","#","^roll:侦察,80,","ev",{"VAR?":"上次骰值"},"out","/ev","^,","ev",{"VAR?":"上次结果"},"out","/ev","/#","^〔侦察 80 · 骰 ","ev",{"VAR?":"上次骰值"},"out","/ev","^ · ","ev",{"f()":"档位名"},"out","/ev","^〕","\n",["ev",{"VAR?":"上次结果"},0,"==","/ev",{"->":".^.b","c":true},{"b":["\n","^柜门撞到墙发出巨响。志勇扭头：\"你他妈翻什么呢？\" 你慌乱中把要找的东西又塞了回去。","\n","ev",{"^var":"恐惧_志勇","ci":-1},{"^var":"状态_志勇","ci":-1},5,{"f()":"调整恐惧"},"pop","/ev","\n",{"->":".^.^.^.48"},null]}],["ev",{"VAR?":"ok"},"/ev",{"->":".^.b","c":true},{"b":["\n","^一把主厨刀，包在油纸里。还有一袋花椒辣椒面。你把它们悄悄塞进床底下伸手就能够到的位置。","\n","ev",true,"/ev",{"VAR=":"主厨刀_unlocked","re":true},"^（你的工具栏更新：主厨刀 / 辣椒面）","\n","ev",{"VAR?":"当前PC"},{"VAR?":"昕"},"==","/ev",[{"->":".^.b","c":true},{"b":["\n","^德国双立人，黑色树脂柄，八寸主厨。你高一暑假打工攒了六周零花钱，在淮海路菜场旁的厨具店亲手挑的——摸过七把，选了这把，因为它拿在手里的重心偏刀背，下刀稳。这不是买来防身的。","\n","^你从枕头底下还摸出一本巴掌大的本子。皮筋扎口，翻开都是手抄的：红烧肉三种火候注记、糖醋排骨调料比例、佛跳墙的简化步骤旁边用括号标注\"汤底可用鸡架代替\"。每一页角落都已经翻软，有些字迹被手汗洇得模糊，自己还是认得出。","\n","^高一结束那个暑假，你跟你妈说过一次想去烹饪学校。她当场哭了，哭得很轻，但你听见了。你爸说让她别管，就两个字，\"别管\"。饭桌上谁都没再提。第二天你们照样三口人吃早饭，豆浆油条，正常的一天。","\n","^你把本子重新塞回枕头底下。你心里清楚这把刀今晚可能要见血——不是切姜片的那种见血，不是飞速起锅前在砧板上最后一刀按下去的那种。是另一种。","\n","^你把刀按在掌心，感觉了一下重量。比你预想的轻。或者比你预想的重。具体哪个，你没分辨清楚。","\n",{"->":".^.^.^.15"},null]}],"nop","\n",{"->":".^.^.^.48"},null]}],[{"->":".^.b"},{"b":["\n","^乱七八糟的旧课本和两双臭袜子。你没找到要找的东西。","\n",{"->":".^.^.^.48"},null]}],"nop","\n",{"->":".^.^.顶层"},null],"对话_志勇":["#","^speaker:zhiyong","/#","ev",{"f()":"tick回合"},"pop","/ev","\n","^志勇咂了一下嘴：\"啧，磨叽什么。要冲早就冲了，要躺平就接着躺平。\" 他抖腿停了一下，又抖回去。","\n","ev",{"^var":"信任_志勇","ci":-1},3,{"f()":"调整信任"},"pop","/ev","\n","#","^state:trust_zhiyong+3","/#",{"->":".^.^.顶层"},null],"对话_张怡":["#","^speaker:zhangyi","/#","ev",{"f()":"tick回合"},"pop","/ev","\n","^张怡推了一下不存在的眼镜：\"我倾向于先把今天能确定的事情列一下……等等，刚刚那声音是从楼上来的吗？\"","\n","ev",{"^var":"信任_张怡","ci":-1},3,{"f()":"调整信任"},"pop","/ev","\n","ev",{"VAR?":"隐约不安"},{"f()":"推进觉知"},"pop","/ev","\n","#","^state:trust_zhangyi+3","/#",{"->":".^.^.顶层"},null],"发呆等待":["ev",{"f()":"tick回合"},"pop","/ev","\n","^寝室里安静下来。志勇换了个姿势继续抖腿。窗外的探照灯扫过铁皮，光斑在墙上慢慢移过去。","\n",{"->":".^.^.顶层"},null],"张怡_预判":["#","^speaker:player","/#","ev",{"f()":"tick回合"},"pop","/ev","\n","ev",{"f()":"tick调查"},"pop","/ev","\n","^你在草稿本上写下六组数字：隔离天数、异常事件的时间点、间隔。折线收敛到今晚。","\n","^今晚有事——不是直觉，是概率。","\n","ev",true,"/ev",{"VAR=":"切入解锁","re":true},"ev",{"VAR?":"隐约不安"},{"f()":"推进觉知"},"pop","/ev","\n","^（今晚的节点已经来了。）","\n",{"->":".^.^.顶层"},null]}],"场景_泡面之争":[["#","^scene:dorm_302","/#","#","^speaker:yanbo","/#","ev",true,"/ev",{"VAR=":"已进过泡面","re":true},"ev",{"f()":"tick回合"},"pop","/ev","\n","^砚波先看见了。零食柜最深处那桶老坛酸菜面——隔离第七天的最后一桶。他一伸手就把它抱到了自己怀里。","\n","^\"这是我的。\" 他说得很认真。","\n","^志勇咂嘴：\"得了吧，刚才是谁说不饿的？\"","\n","^张怡正色：\"我倾向于按抽签决定。\"","\n","^你小声：\"要不……四个人分着煮？我的意思是，万一……\"","\n","ev","str","^支持抽签","/str","/ev",{"*":".^.c-0","flg":20},"ev","str","^支持平分","/str","/ev",{"*":".^.c-1","flg":20},"ev","str","^让砚波自己吃","/str","/ev",{"*":".^.c-2","flg":20},{"c-0":["\n","ev",{"^var":"信任_张怡","ci":-1},5,{"f()":"调整信任"},"pop","/ev","\n","^抽签结果是张怡。砚波抱怨着把面让出去，张怡反而把面推回锅里：\"四个人分。\"","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["\n","^你松了口气。志勇骂骂咧咧地接过煮面的活。","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["\n","^砚波得意地把面带到桌前。你看着空锅，没说话。","\n",{"->":".^.^.g-0"},{"#f":5}],"g-0":["^水开了，热气腾起来，混进日光灯昏黄的光里。","\n","ev",{"f()":"推进伏笔"},"pop","/ev","\n","ev",{"VAR?":"闻到甜腥"},{"f()":"推进觉知"},"pop","/ev","\n",["ev",{"VAR?":"当前伏笔"},{"VAR?":"一档伏笔"},"?","/ev",{"->":".^.b","c":true},{"b":["\n","^煮面时空气里飘起一丝奇怪的甜腥味——大概是包受潮了。","\n",{"->":".^.^.^.16"},null]}],["ev",{"VAR?":"当前伏笔"},{"VAR?":"二档伏笔"},"?","/ev",{"->":".^.b","c":true},{"b":["\n","^走廊那头的灯隐约比平时暗一拍，但很快恢复。","\n",{"->":".^.^.^.16"},null]}],["ev",{"VAR?":"当前伏笔"},{"VAR?":"三档伏笔"},"?","/ev",{"->":".^.b","c":true},{"b":["\n","^翻找时摸到一张陌生的纸条，字迹潦草：\"别开门。\"","\n",{"->":".^.^.^.16"},null]}],"nop","\n",{"->":"场景_寝室傍晚.顶层"},null]}],null],"场景_夜半叩门":[["#","^scene:dorm_302","/#","#","^sfx:knock_3x","/#","ev",{"f()":"tick回合"},"pop","/ev","\n","ev",{"VAR?":"第一次敲门"},{"f()":"推进觉知"},"pop","/ev","\n","^不知道什么时候，寝室里所有人都停下了。","\n","^门外，传来三下敲门声。节奏整齐：咚——咚——咚。","\n","^然后是停顿。","\n","^你的脸刷一下白了，你贴墙缩了一下。志勇站起身但没有动。张怡轻声：\"等等——\"","\n","ev","str","^大声问 \"谁\"","/str","/ev",{"*":".^.c-0","flg":20},["ev",{"^->":"场景_夜半叩门.0.31.$r1"},{"temp=":"$r"},"str",{"->":".^.s"},[{"#n":"$r1"}],"/str","/ev",{"*":".^.^.c-1","flg":18},{"s":["^〔聆听 65〕屏住呼吸听",{"->":"$r","var":true},null]}],"ev","str","^让志勇过去看","/str","/ev",{"*":".^.c-2","flg":20},{"c-0":["\n","^你的声音在寝室里回荡了一下。门外没有任何回应。","\n","ev",{"VAR?":"当前PC"},{"VAR?":"砚波"},"==","/ev",[{"->":".^.b","c":true},{"b":["\n","^但你其实不是在问。","\n","^你问\"谁\"的时候，眼睛一直盯着门缝——走廊灯从门缝底下透进来一条光，光里有一道影。","\n","^影子的比例不对。肩膀太高，脑袋太偏，像是脖子没有骨头支撑，靠什么别的东西顶着。","\n","^活人站着的时候，重心在脚上。那个影子的重心在别的地方。","\n","^你在心里认定了：那不是人，那是什么东西穿着衣服。","\n","^但你没说出来。说出来也没有用。","\n","ev",{"VAR?":"门外有东西"},{"f()":"推进觉知"},"pop","/ev","\n",{"->":".^.^.^.9"},null]}],"nop","\n",{"->":".^.^.g-0"},{"#f":5}],"c-1":["ev",{"^->":"场景_夜半叩门.0.c-1.$r2"},"/ev",{"temp=":"$r"},{"->":".^.^.31.s"},[{"#n":"$r2"}],"\n","ev",65,{"f()":"掷技能"},"/ev",{"temp=":"听见"},"\n","#","^roll:聆听,65,","ev",{"VAR?":"上次骰值"},"out","/ev","^,","ev",{"VAR?":"上次结果"},"out","/ev","/#","^〔聆听 65 · 骰 ","ev",{"VAR?":"上次骰值"},"out","/ev","^ · ","ev",{"f()":"档位名"},"out","/ev","^〕","\n",["ev",{"VAR?":"听见"},"/ev",{"->":".^.b","c":true},{"b":["\n","^门后有呼吸声——缓慢，潮湿，带着某种不属于活物的节律。","\n","ev",{"VAR?":"门外有东西"},{"f()":"推进觉知"},"pop","/ev","\n",{"->":".^.^.^.39"},null]}],[{"->":".^.b"},{"b":["\n","^门后是绝对的安静，安静到不真实。","\n","ev",{"VAR?":"当前PC"},{"VAR?":"砚波"},"==","/ev",[{"->":".^.b","c":true},{"b":["\n","^你蹲下来，把脸贴近门缝。","\n","^什么都没有——没有脚步，没有衣服蹭墙的声音，连喘气都没有。","\n","^但这就是答案了。","\n","^活物哪怕屏住呼吸，心跳还是会让身体轻微地动，衣服会蹭，喉咙会收紧发出一点点声音。","\n","^门后这种安静不属于任何活的东西。","\n","^你站起来，没有表情。","\n","ev",{"VAR?":"门外有东西"},{"f()":"推进觉知"},"pop","/ev","\n",{"->":".^.^.^.9"},null]}],"nop","\n",{"->":".^.^.^.39"},null]}],"nop","\n",{"->":".^.^.g-0"},{"#f":5}],"c-2":["\n","^志勇撇嘴：\"看就看。\" 他走到门边把耳朵贴上去——又立刻退回来，没说话。","\n","ev",{"^var":"恐惧_志勇","ci":-1},{"^var":"状态_志勇","ci":-1},8,{"f()":"调整恐惧"},"pop","/ev","\n","#","^state:fear_zhiyong+8","/#","ev",{"VAR?":"当前PC"},{"VAR?":"砚波"},"==","/ev",[{"->":".