// _helpers.ink — 状态/检定/伏笔/战斗 helper 函数
// 由 kongjiang_act0.ink 通过 INCLUDE 引入

// 切换互斥 LIST 状态：清空当前所有值，加入新值
=== function 切换状态(ref s, 新状态)
    ~ s -= LIST_ALL(s)
    ~ s += 新状态

// 调整 fear（数值），clamp 到 0–100，>=50 自动迁 平静→紧张
=== function 调整恐惧(ref f, ref s, 增量)
    ~ f = f + 增量
    { f > 100:
        ~ f = 100
    }
    { f < 0:
        ~ f = 0
    }
    { f >= 50 && (s ? 平静):
        ~ s -= LIST_ALL(s)
        ~ s += 紧张
    }

// 调整 trust（数值），clamp 到 0–100
=== function 调整信任(ref t, 增量)
    ~ t = t + 增量
    { t > 100:
        ~ t = 100
    }
    { t < 0:
        ~ t = 0
    }

// 调整 SAN（数值），clamp 到 0
=== function 调整理智(ref s, 增量)
    ~ s = s + 增量
    { s < 0:
        ~ s = 0
    }

// 调整 HP（数值），clamp 到 0
=== function 调整生命(ref h, 增量)
    ~ h = h + 增量
    { h < 0:
        ~ h = 0
    }

// 每轮自动 fear 衰减 -2（gm_base.md fear-decay 规则）
=== function 每轮恐惧衰减()
    ~ 调整恐惧(恐惧_志勇, 状态_志勇, -2)
    ~ 调整恐惧(恐惧_张怡, 状态_张怡, -2)

// 推进觉知链：自动把链上 min..目标 全部加入已知集
=== function 推进觉知(目标)
    ~ 觉知 += LIST_RANGE(LIST_ALL(目标), LIST_MIN(LIST_ALL(目标)), 目标)

// 推进伏笔档：无→一档→二档→三档（封顶）
=== function 推进伏笔()
    {
    - 当前伏笔 ? 无伏笔:
        ~ 当前伏笔 -= 无伏笔
        ~ 当前伏笔 += 一档伏笔
    - 当前伏笔 ? 一档伏笔:
        ~ 当前伏笔 -= 一档伏笔
        ~ 当前伏笔 += 二档伏笔
    - 当前伏笔 ? 二档伏笔:
        ~ 当前伏笔 -= 二档伏笔
        ~ 当前伏笔 += 三档伏笔
    }

// CoC 7e d100 vs 技能值检定，五档结果，写入 上次骰值 / 上次结果
// return 是否通过（普通成功及以上）
=== function 掷技能(技能值)
    ~ 上次骰值 = RANDOM(1, 100)
    {
    - 上次骰值 == 1:
        ~ 上次结果 = 5
    - 上次骰值 <= 技能值 / 5:
        ~ 上次结果 = 4
    - 上次骰值 <= 技能值 / 2:
        ~ 上次结果 = 3
    - 上次骰值 <= 技能值:
        ~ 上次结果 = 2
    - 技能值 < 50 && 上次骰值 >= 96:
        ~ 上次结果 = 0
    - 上次骰值 == 100:
        ~ 上次结果 = 0
    - else:
        ~ 上次结果 = 1
    }
    ~ return 上次结果 >= 2

// 骰子档位名（用于 〔...〕 块内 {档位名()} 插值）
=== function 档位名()
    {
    - 上次结果 == 0:
        大失败！
    - 上次结果 == 1:
        失败
    - 上次结果 == 2:
        成功
    - 上次结果 == 3:
        困难成功
    - 上次结果 == 4:
        极难成功
    - 上次结果 == 5:
        大成功！
    }

// 回合 tick：+1、衰减、检测切入解锁
=== function tick回合()
    ~ 回合数 = 回合数 + 1
    ~ 每轮恐惧衰减()
    { (调查数 >= 3 || 回合数 >= 5) && 切入解锁 == false:
        ~ 切入解锁 = true
    }

// 调查 tick：+1，并复检切入解锁条件（防止 tick 顺序导致漏触发）
=== function tick调查()
    ~ 调查数 = 调查数 + 1
    { (调查数 >= 3 || 回合数 >= 5) && 切入解锁 == false:
        ~ 切入解锁 = true
    }

// 渐进式 v2：推进 act_phase。Act1/Act2 入口和喘息夜2 进入时调用。
// 显式赋值（不支持自增），便于将来加日志 / 统一 hook。
=== function 推进阶段(到)
    ~ act_phase = 到

// === 多 PC 系统：PC 选择初始化（spec §2.2）===
// 4 PC 各自的 default stats（来自 index.html PC_DATA + COMPANIONS）
=== function 初始化PC(pc)
~ 当前PC = pc
{
- pc == 昕:
    ~ 当前PC名 = "罗昕"
    ~ 当前PC昵称 = "昕"
    ~ 理智_PC = 64
    ~ HP_PC = 12
    ~ 信任_砚波 = 70
    ~ 信任_志勇 = 60
    ~ 信任_张怡 = 65
    ~ 恐惧_砚波 = 25
    ~ 恐惧_志勇 = 20
    ~ 恐惧_张怡 = 25
- pc == 砚波:
    ~ 当前PC名 = "砚波"
    ~ 当前PC昵称 = "砚波"
    ~ 理智_PC = 60
    ~ HP_PC = 12
    ~ 信任_昕 = 70
    ~ 信任_志勇 = 50
    ~ 信任_张怡 = 55
    ~ 恐惧_昕 = 30
    ~ 恐惧_志勇 = 25
    ~ 恐惧_张怡 = 30
- pc == 志勇:
    ~ 当前PC名 = "志勇"
    ~ 当前PC昵称 = "志勇"
    ~ 理智_PC = 60
    ~ HP_PC = 16
    ~ 信任_昕 = 65
    ~ 信任_砚波 = 60
    ~ 信任_张怡 = 50
    ~ 恐惧_昕 = 25
    ~ 恐惧_砚波 = 30
    ~ 恐惧_张怡 = 35
- else:
    ~ 当前PC名 = "张怡"
    ~ 当前PC昵称 = "张怡"
    ~ 理智_PC = 70
    ~ HP_PC = 10
    ~ 信任_昕 = 55
    ~ 信任_砚波 = 55
    ~ 信任_志勇 = 45
    ~ 恐惧_昕 = 35
    ~ 恐惧_砚波 = 30
    ~ 恐惧_志勇 = 35
}
