// 决定路径（多数胜，平票时 PC 决定）
{
- 票_突围 > 票_天台 && 票_突围 > 票_仪式:
    ~ Act3路径 = 1
- 票_天台 > 票_突围 && 票_天台 > 票_仪式:
    ~ Act3路径 = 2
- 票_仪式 > 票_突围 && 票_仪式 > 票_天台:
    ~ Act3路径 = 3
- else:
